# Single root env file. The server loads this via dotenv; Vite reads it through
# `envDir: ".."` and only exposes VITE_-prefixed vars to the browser bundle.
# Copy to `.env` and fill in real values. Never commit `.env`.

# ---- Server (secret - never shipped to the browser) ----
NODE_ENV=development
API_PORT=3001
CORS_ORIGIN=http://localhost:5173

# Supabase (server side)
SUPABASE_URL=https://YOUR-PROJECT.supabase.co
SUPABASE_ANON_KEY=your-supabase-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# Google Gemini
GEMINI_API_KEY=your-gemini-api-key
GEMINI_MODEL=gemini-2.0-flash
# Set to 1 to run the app and tests with canned AI responses (no real key needed).
GEMINI_MOCK=0

# Rate limiting for AI endpoints (/api/chat, /api/end-session)
AI_RATE_LIMIT_WINDOW_MS=60000
AI_RATE_LIMIT_MAX=20

# ---- Client (Vite - PUBLIC, only non-secret values) ----
VITE_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
VITE_SUPABASE_ANON_KEY=your-supabase-anon-key
VITE_API_BASE_URL=http://localhost:3001/api
